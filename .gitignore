# --- Launch Settings (configuracao local por maquina) -------------------------
# Cada dev tem porta/perfil diferente -- nao commitar
**/Properties/launchSettings.json

# --- Segredos e configuracoes sensiveis ---------------------------------------
# NUNCA commitar -- podem conter connection strings, chaves de API, senhas
appsettings.Production.json
appsettings.Staging.json
secrets.json

# appsettings.json e appsettings.Development.json SAO commitados:
# contÃªm apenas Biometric:HubUrl -- sem dados sensiveis
!appsettings.json
!appsettings.Development.json

# --- DLLs nativas Futronic (binarios proprietarios) --------------------------
# ftrScanAPI.dll e ftrAnsiSdk.dll sao binarios x86 proprietarios da Futronic.
# NAO entram no repositorio: licenca proprietaria + tamanho (~1.2 MB).
#
# Como obter em uma maquina nova:
#   Copiar de CmsoAgendamento\docs\ para Cmso.Biometric.Agent.Core\
#   O build ira falhar sem elas -- comportamento esperado.
**/ftrScanAPI.dll
**/ftrAnsiSdk.dll

# --- Atalhos Windows ----------------------------------------------------------
# Arquivos .lnk sao especificos da maquina de desenvolvimento
*.lnk

